NAIOSH_SESSION_SECRET="replace-with-a-long-random-secret"

# Optional compatibility aliases also supported by the session layer:
# AUTH_SECRET="replace-with-a-long-random-secret"
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Local demos can use the built-in fallback secret. Production requires an explicit
# secret unless this escape hatch is intentionally enabled.
# NAIOSH_ALLOW_DEMO_SESSION_SECRET="false"

# Demo accounts are disabled in production unless explicitly enabled for a controlled demo.
# NAIOSH_ENABLE_DEMO_LOGIN="false"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naiosh_law"
DATABASE_POOL_MAX=5

# Use a long random value in production. JWT_SECRET, AUTH_SECRET, or NEXTAUTH_SECRET are accepted.
JWT_SECRET="replace-with-a-long-random-secret"

# Set to true in production environments that must fail closed when no secret is configured.
NAIOSH_REQUIRE_SESSION_SECRET=false
# PostgreSQL (Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT secret for auth cookies
JWT_SECRET="change-this-to-a-long-random-string-in-production"

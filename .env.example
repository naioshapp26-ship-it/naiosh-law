# Required in production unless demo fallback is intentionally enabled.
NAIOSH_SESSION_SECRET="replace-with-a-long-random-secret"

# Alternative secret names supported by the session token helper.
# AUTH_SECRET=""
# NEXTAUTH_SECRET=""

# Development/demo escape hatch only. Leave false in real deployments.
NAIOSH_ALLOW_DEMO_SESSION_SECRET=false

# Required to allow bundled demo credentials or quick demo login in production.
NAIOSH_ENABLE_DEMO_LOGIN=false

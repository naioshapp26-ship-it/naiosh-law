NAIOSH_SESSION_SECRET="replace-with-a-long-random-secret"

# Optional compatibility aliases also supported by the session layer:
# AUTH_SECRET="replace-with-a-long-random-secret"
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Demo login is disabled in production unless explicitly enabled.
# NAIOSH_ENABLE_DEMO_LOGIN="true"

# Temporary demos only: allows the development fallback session secret in production.
# NAIOSH_ALLOW_DEMO_SESSION_SECRET="true"

# Local HTTP-only production smoke tests only: disables Secure on session cookies.
# NAIOSH_ALLOW_INSECURE_SESSION_COOKIE="true"

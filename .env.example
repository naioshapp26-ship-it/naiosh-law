# Copy to .env.local for local overrides. Do not commit real secrets.

# Required for production sessions unless NAIOSH_ALLOW_DEMO_SESSION_SECRET=true is set intentionally.
NAIOSH_SESSION_SECRET=replace-with-a-long-random-secret

# Optional aliases also supported by the session signer:
# AUTH_SECRET=replace-with-a-long-random-secret
# NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Demo-only escape hatch for production previews without a secret.
# NAIOSH_ALLOW_DEMO_SESSION_SECRET=true

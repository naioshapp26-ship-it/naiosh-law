# Use a private stable value for real deployments.
NAIOSH_SESSION_SECRET="replace-with-a-long-random-secret"

# Alternative secret names supported by the session token helper.
# AUTH_SECRET=""
# NEXTAUTH_SECRET=""

# Demo-only switches. Leave both disabled for real deployments.
NAIOSH_ENABLE_DEMO_LOGIN=false
NAIOSH_ALLOW_DEMO_SESSION_SECRET=false
